CREATE TABLE Ex3(
item_id INTEGER,
item_name VARCHAR(30),
checkin_date DATE,
item_price NUMBER(10,3),
branch_name VARCHAR(200),
consumer_name VARCHAR(20),
place VARCHAR(20)
);

