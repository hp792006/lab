SELECT * FROM Ex3;

-- String
SELECT UPPER(item_name) FROM Ex3;
SELECT INITCAP(item_name) FROM Ex3;
SELECT TRIM(BOTH 'e' FROM item_name) FROM Ex3;

-- Date
SELECT ADD_MONTHS(TO_DATE('2024-02-20','YYYY-MM-DD'),3) FROM dual;
SELECT LAST_DAY(TO_DATE('2024-03-11','YYYY-MM-DD')) FROM dual;

-- Number
SELECT MAX(item_price), MIN(item_price),
ROUND(AVG(item_price),1), SUM(item_price) FROM Ex3;

-- Conversion
SELECT TO_CHAR(SYSDATE,'dd') FROM dual;
SELECT TO_CHAR(SYSDATE,'ddth') FROM dual;
